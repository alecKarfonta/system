# =============================================================================
#  cluster.env  -  central configuration for your homelab GPU cluster
#  Copy this file to  cluster.env  and edit the values below.
#      cp config/cluster.env.example config/cluster.env
#  Everything in the repo reads from this one file.
# =============================================================================

# --- Identity ---------------------------------------------------------------
CLUSTER_NAME="homelab"

# The first control-plane node's IP or hostname, as seen by the OTHER machines.
# If you use Tailscale (below), use its tailnet IP/hostname here.
SERVER_HOST="192.168.1.10"

# Port the k3s API listens on. Leave as-is unless you know you changed it.
SERVER_PORT="6443"

# --- Versions (pin these so re-runs are reproducible) -----------------------
# k3s channel: "stable" tracks the latest stable. Pin to e.g. "v1.34" for control.
# DRA (per-GPU targeting) needs Kubernetes >= 1.34.
K3S_CHANNEL="stable"

# Helm chart versions. "" means "latest at install time".
GPU_OPERATOR_VERSION=""        # NVIDIA GPU Operator
NVIDIA_DRA_VERSION=""          # NVIDIA DRA Driver for GPUs
LONGHORN_VERSION=""            # Replicated block storage
MONITORING_VERSION=""          # kube-prometheus-stack

# --- Networking -------------------------------------------------------------
# If your machines are all on one LAN, leave TAILSCALE_ENABLED=0.
# If they are behind CGNAT / spread across networks, set this to 1 and provide
# a Tailscale auth key (https://login.tailscale.com/admin/settings/keys).
TAILSCALE_ENABLED="0"
TAILSCALE_AUTHKEY=""

# Disable k3s' bundled Traefik ingress + servicelb if you'd rather run your own.
# Safe to leave as-is for a first cluster.
K3S_DISABLE_TRAEFIK="0"
K3S_DISABLE_SERVICELB="0"

# --- Drivers ----------------------------------------------------------------
# On consumer GPUs (30xx/40xx/50xx) it is usually MOST reliable to install the
# NVIDIA driver on the host yourself (apt) and let the GPU Operator skip it.
#   1 = GPU Operator installs/manages the driver (good for datacenter cards)
#   0 = driver already installed on the host (recommended for consumer cards)
GPU_OPERATOR_MANAGES_DRIVER="0"

# --- Stack components (1=install, 0=skip) -----------------------------------
INSTALL_GPU_OPERATOR="1"
INSTALL_DRA_DRIVER="1"
INSTALL_LONGHORN="1"
INSTALL_MONITORING="1"
INSTALL_DASHBOARD="1"      # Headlamp web GUI for the cluster

# Pin the Headlamp chart version if you want ("" = latest at install time).
DASHBOARD_VERSION=""
